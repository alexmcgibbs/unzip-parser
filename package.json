{
  "name": "webhook-zip-worker",
  "version": "1.0.0",
  "description": "Express TypeScript webhook service that unzips uploaded archives in a worker thread",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "npm run build && npm run start",
    "test": "npm run build && node --test --test-concurrency=1 tests"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "got": "^11.8.6",
    "pg": "^8.13.3",
    "pg-boss": "^10.4.2",
    "poolifier": "^5.3.2",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.10",
    "@types/unzipper": "^0.10.11",
    "supertest": "^7.1.1",
    "typescript": "^5.8.2"
  }
}
